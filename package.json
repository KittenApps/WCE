  "dependencies": {
    "buttplug": "^3.2.2",
    "dexie": "^4.0.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.10.0",
    "@stylistic/eslint-plugin": "^2.7.2",
    "@total-typescript/ts-reset": "^0.6.1",
    "@types/events": "^3.0.3",
    "@types/node": "^22.5.4",
    "bc-stubs": "^107.0.0",
    "bondage-club-mod-sdk": "^1.2.0",
    "eslint": "^9.10.0",
    "globals": "^15.9.0",
    "rolldown": "^0.13.2-snapshot-afc4825-20240909003318",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.4.0",
    "ws": "^8.18.0"
  },
  "overrides": {
    "bc-stubs": {
      "socket.io-client": {
        "engine.io-client": {
          "ws": "$ws"
