    "dexie": "^4.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "@stylistic/eslint-plugin": "^3.1.0",
    "@total-typescript/ts-reset": "^0.6.1",
    "@types/events": "^3.0.3",
    "@types/node": "^22.13.4",
    "bc-stubs": "^113.0.0",
    "bondage-club-mod-sdk": "^1.2.0",
    "eslint": "^9.20.1",
    "globals": "^15.15.0",
    "rolldown": "^1.0.0-beta.3",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.24.0",
    "ws": "^8.18.0"
  },
  "overrides": {
